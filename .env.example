# ── Local dev (Supabase CLI + Docker) ───────────────────────────────────────
# 1. npm run supabase:start
# 2. npm run env:local          → writes .env from running stack
# 3. npm run seed:local         → populates the words table
# 4. npm run dev
#
# Studio UI: http://127.0.0.1:54323
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# ── Production (hosted Supabase) ────────────────────────────────────────────
# Dashboard → Project Settings → API Keys
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Secret key — seed script only, never commit or expose to the client.
# Local:  npm run seed:local
# Prod:   SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=sb_secret_... npm run seed
